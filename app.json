{
  "expo": {
    "name": "DeepfakeShield",
    "slug": "deepfake-shield",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#1C1B1F"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vmaroon95.deepfakeshield",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "DeepfakeShield needs access to analyze images and videos for deepfake detection."
      }
    },
    "android": {
      "package": "com.vmaroon95.deepfakeshield",
      "intentFilters": [
        {
          "action": "SEND",
          "category": ["DEFAULT"],
          "data": [
            { "mimeType": "image/*" },
            { "mimeType": "video/*" }
          ]
        }
      ]
    },
    "plugins": [
      "expo-sharing",
      [
        "expo-image-picker",
        {
          "photosPermission": "DeepfakeShield needs access to analyze media for deepfake detection."
        }
      ]
    ]
  }
}
