{
  "expo": {
    "name": "DeepfakeShield",
    "slug": "deepfakeshield",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1C1B1F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.varunmeda.deepfakeshield",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "DeepfakeShield needs access to analyze images and videos for deepfake detection.",
        "CFBundleDocumentTypes": [
          {
            "CFBundleTypeName": "Media",
            "LSHandlerRank": "Alternate",
            "LSItemContentTypes": [
              "public.image",
              "public.movie"
            ]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1C1B1F"
      },
      "package": "com.varunmeda.deepfakeshield",
      "intentFilters": [
        {
          "action": "SEND",
          "category": ["DEFAULT"],
          "data": [
            { "mimeType": "image/*" },
            { "mimeType": "video/*" }
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sharing",
      [
        "expo-image-picker",
        {
          "photosPermission": "DeepfakeShield needs access to analyze media for deepfake detection."
        }
      ]
    ]
  }
}
